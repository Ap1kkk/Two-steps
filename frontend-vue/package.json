{
  "name": "frontend-vue",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "start": "webpack serve --config webpack/webpack.config.js --env env=dev",
    "build": "cross-env NODE_ENV=production webpack --config webpack/webpack.config.js --env env=prod",
    "test:unit": "vue-cli-service test:unit",
    "test:e2e": "vue-cli-service test:e2e",
    "lint": "eslint --fix \"./src/**/*.{js,jsx,ts,tsx,json}\"",
    "stylelint": "stylelint \"src/**/*.scss\"",
    "stylelint:fix": "stylelint \"src/**/*.scss\" --fix",
    "format": "prettier --write \"./src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\" --ignore-path ./.prettierignore",
    "test": "npm run stylelint:fix && npm run lint && npm run format"
  },
  "dependencies": {
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "vue": "^3.2.13",
    "vue-class-component": "^8.0.0-0",
    "vue-router": "^4.0.3",
    "vuex": "^4.0.0"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.0.1",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@typescript-eslint/eslint-plugin": "^5.4.0",
    "@typescript-eslint/parser": "^5.4.0",
    "@vue/cli-plugin-babel": "^5.0.9",
    "@vue/cli-plugin-e2e-cypress": "~5.0.9",
    "@vue/cli-plugin-eslint": "^5.0.9",
    "@vue/cli-plugin-router": "^5.0.9",
    "@vue/cli-plugin-typescript": "~5.0.9",
    "@vue/cli-plugin-unit-jest": "~5.0.9",
    "@vue/cli-plugin-unit-mocha": "~5.0.9",
    "@vue/cli-plugin-vuex": "^5.0.9",
    "@vue/cli-service": "^5.0.9",
    "@vue/compiler-sfc": "^3.5.29",
    "@vue/eslint-config-typescript": "^9.1.0",
    "@vue/test-utils": "^2.0.0-0",
    "autoprefixer": "^10.4.27",
    "chai": "^5.3.3",
    "clean-webpack-plugin": "^4.0.0",
    "commitizen": "^4.2.4",
    "cross-env": "^7.0.3",
    "css-loader": "^6.8.1",
    "css-minimizer-webpack-plugin": "^7.0.4",
    "cssnano": "^7.1.2",
    "cypress": "^13.17.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-vue": "^8.0.3",
    "html-webpack-plugin": "^5.5.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "mini-css-extract-plugin": "^2.7.6",
    "mocha": "^10.8.2",
    "postcss-loader": "^7.3.3",
    "prettier": "^2.8.8",
    "sass": "^1.32.7",
    "sass-loader": "^12.0.0",
    "style-loader": "^3.3.3",
    "stylelint": "^16.1.0",
    "stylelint-config-standard-scss": "^13.0.0",
    "stylelint-order": "^6.0.3",
    "ts-loader": "^9.4.3",
    "typescript": "^5.0.4",
    "typescript-plugin-css-modules": "^5.0.1",
    "url-loader": "^4.1.1",
    "vue-loader": "^17.4.2",
    "webpack": "^5.81.0",
    "webpack-cli": "^5.0.2",
    "webpack-dev-server": "^5.2.3",
    "webpack-merge": "^6.0.1"
  },
  "overrides": {
    "minimist": "^1.2.8",
    "minimatch": "^9.0.5",
    "lodash": "^4.17.21",
    "qs": "^6.14.1",
    "tough-cookie": "^4.1.4",
    "postcss": "^8.4.49",
    "braces": "^3.0.3",
    "glob-parent": "^6.0.2",
    "serialize-javascript": "^6.0.2",
    "debug": "^4.4.0",
    "elliptic": "^6.6.1",
    "moment": "^2.30.1",
    "tmp": "^0.2.3",
    "cross-spawn": "^7.0.6",
    "ajv": "^8.17.1",
    "request": "npm:@cypress/request@^3.0.6",
    "request-promise-native": "npm:@cypress/request-promise@^5.0.0",
    "form-data": "^4.0.1",
    "nanoid": "^5.0.9",
    "js-yaml": "^4.1.0",
    "diff": "^7.0.0"
  },
  "resolutions": {
    "minimatch": "^9.0.5",
    "postcss": "^8.4.49"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended",
      "@vue/typescript/recommended",
      "plugin:prettier/recommended"
    ],
    "parserOptions": {
      "ecmaVersion": 2020
    },
    "rules": {},
    "overrides": [
      {
        "files": [
          "**/__tests__/*.{j,t}s?(x)",
          "**/tests/unit/**/*.spec.{j,t}s?(x)"
        ],
        "env": {
          "mocha": true
        }
      }
    ]
  },
  "lint-staged": {
    "*.{css,scss}": "npm run stylelint:fix",
    "*.{js,jsx,ts,tsx}": "npm run lint",
    "*.{js,jsx,ts,tsx,json,css,scss,md}": "npm run format"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "homepage": "./"
}
